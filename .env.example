# OpenClaw Memory System 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ==================== Weaviate 配置 ====================
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# ==================== Ollama 配置 ====================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2:3b

# ==================== API 配置 ====================
API_PORT=8082

# ==================== 存储配置 ====================
DATA_DIR=./data

# ==================== Agent 配置 ====================
# OpenClaw 根目录
OPENCLAW_DIR=~/.openclaw

# ==================== 日志配置 ====================
LOG_LEVEL=INFO