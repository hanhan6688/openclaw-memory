# OpenClaw Memory System - Git Ignore
# ================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/

# 数据目录（运行时生成）
data/
kg_data/

# 日志文件
*.log
logs/

# 系统文件
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 环境变量（可能包含敏感信息）
.env
.env.local
.env.*.local

# 临时文件
*.tmp
*.temp
*.bak
.cache/

# 测试覆盖率
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# 分发/打包
dist/
build/
*.egg-info/
*.egg

# Jupyter Notebook
.ipynb_checkpoints

# Node.js（如果有前端）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Weaviate 数据
weaviate_data/

# 运行时状态文件
sync_state.json
sync_state.json.bak
api.pid

# NebulaGraph 数据
nebula/data/
